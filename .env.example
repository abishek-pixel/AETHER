# ============================================================
# Aether — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is in .gitignore.
# NEVER put real credentials in this file.
# ============================================================

# ── LLM Providers ────────────────────────────────────────────
# Groq: https://console.groq.com/keys
GROQ_API_KEY=gsk_REPLACE_WITH_YOUR_GROQ_KEY

# Google Gemini (optional fallback)
GOOGLE_API_KEY=REPLACE_WITH_YOUR_GOOGLE_API_KEY

# Ollama (local, optional)
OLLAMA_BASE_URL=http://localhost:11434

# ── Search APIs ───────────────────────────────────────────────
# Tavily: https://app.tavily.com/
TAVILY_API_KEY=tvly-REPLACE_WITH_YOUR_TAVILY_KEY

# Serper: https://serper.dev/
SERPER_API_KEY=REPLACE_WITH_YOUR_SERPER_KEY

# ── PostgreSQL ────────────────────────────────────────────────
# LOCAL development (.env file):
#   DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/aether
# PRODUCTION (Render environment variable — set in Render dashboard):
#   DATABASE_URL=<Render Internal Database URL>
#
# The code auto-normalises postgres:// → postgresql+asyncpg://
# so you can paste the Render URL directly without modification.
DATABASE_URL=

# ── JWT Authentication ────────────────────────────────────────
# Generate a secure random key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_64_CHAR_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Neo4j (optional — app works without it) ──────────────────
# Cloud: neo4j+s://YOUR_INSTANCE.databases.neo4j.io
NEO4J_URI=neo4j+s://REPLACE_WITH_YOUR_NEO4J_INSTANCE.databases.neo4j.io
NEO4J_USER=REPLACE_WITH_YOUR_NEO4J_USER
NEO4J_PASSWORD=REPLACE_WITH_YOUR_NEO4J_PASSWORD

# ── Qdrant (optional — app works without it) ─────────────────
# Cloud: https://your-cluster.qdrant.io  (set QDRANT_HOST to the hostname)
QDRANT_HOST=localhost
QDRANT_PORT=6333
# QDRANT_API_KEY=REPLACE_IF_USING_CLOUD_QDRANT

# ── Redis (optional — currently not used at runtime) ─────────
REDIS_URL=redis://localhost:6379

# ── Application Limits ────────────────────────────────────────
MAX_ITERATIONS=5
CONFIDENCE_THRESHOLD=0.7
COST_LIMIT_PER_SESSION=1.0

# ── Frontend (set on Vercel, not in backend .env) ─────────────
# VITE_API_BASE_URL=https://your-backend.onrender.com
